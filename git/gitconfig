# vim:ft=gitconfig:expandtab
[user]
    name = Michael Lerch
    email = mdlerch@gmail.com
[core]
    editor = nvim
    excludesfile = ~/.gitignore_global
[color]
    ui = auto
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold
[color "status"]
    added = green bold
    changed = red bold
    untracked = cyan
[color "decorate"]
    branch = red bold
    remoteBranch = green bold
    tag = blue bold
    stash = red
    HEAD = green
[alias]
    tracked = "ls-files --error-unmatch"
    lg = "log --pretty=format:'%C(bold yellow)%h%C(reset) %C(auto)%d%C(reset) %s %C(cyan)[%ar]%C(reset) %C(brightgreen)<%an>%C(reset)' --graph --abbrev-commit --date=local --all"
    unadd = "restore --staged"
    pushall = "push -u origin --all"
    dt = difftool
    st = "status -sb"
    difftex = "difftool -y -t latex"
    ff = "merge --ff-only"
[init]
    defaultBranch = main
[fetch]
    prune = true
[merge]
    tool = nvimdiff
[difftool]
    prompt = false
[mergetool "nvimdiff"]
    path = nvim
[pull]
    rebase = true
[difftool "latex"]
    cmd = latexdiff "$LOCAL" "$REMOTE"
