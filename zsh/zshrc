# vim: ft=zsh

# --- Options ---
setopt rmstarsilent   # suppress "are you sure?" prompt on rm *
setopt prompt_subst   # allow command substitution and expansion in PROMPT
setopt auto_cd        # type a directory name without cd to enter it

# --- Colors ---
# Loads $fg[], $fg_bold[], $bg[], and $reset_color for use in the prompt
autoload -Uz colors
colors

# --- Prompt ---
autoload -Uz vcs_info

zstyle ':vcs_info:*' check-for-changes true
zstyle ':vcs_info:*' stagedstr '%F{10} ...%f'
zstyle ':vcs_info:*' unstagedstr '%F{9} +++%f'
zstyle ':vcs_info:*' enable git

precmd () {
    # Skip git checks in pi/vault — repo is too large, causes noticeable prompt lag
    if [[ "$PWD" == "$HOME/pi/vault"* ]]; then
        vcs_info_msg_0_=''
        return
    fi
    local untracked
    untracked=$(git ls-files --other --exclude-standard --max-count=1 2> /dev/null)
    if [[ -z $untracked ]] {
        zstyle ':vcs_info:*' formats ' [%F{10}%b%c%u%f]'
    } else {
        # !!! signals untracked files are present
        zstyle ':vcs_info:*' formats ' [%F{10}%b%F{6} !!!%c%u%f]'
    }
    vcs_info
}

# Smiley reflects last command exit status: :) on success, :( on failure
local smiley="%(?,%{$fg_bold[green]%}:%)%{$reset_color%},%{$fg_bold[red]%}:(%{$reset_color%})"

PROMPT='[%(#~%{$fg_bold[red]%}>root< %{$reset_color%}~)%{$fg_bold[green]%}%m%{$reset_color%}] %{$fg[yellow]%}> %{$reset_color%}%~${vcs_info_msg_0_}
${smiley} '

# --- History ---
# SHARE_HISTORY: writes and reads history in real-time across all open sessions
# SAVEHIST >> HISTSIZE: file accumulates far more than any single session holds in memory
setopt SHARE_HISTORY
setopt hist_ignore_all_dups
setopt HIST_IGNORE_SPACE      # don't save commands starting with a space
setopt HIST_REDUCE_BLANKS     # remove extra blanks from commands
setopt HIST_EXPIRE_DUPS_FIRST # delete duplicates first when history is full
export HISTSIZE=100000
export SAVEHIST=1000000
export HISTFILE="$HOME/.zsh_history"

# --- Completion ---
# -Uz: standard flags — zsh-style loading, suppress alias expansion
autoload -Uz compinit
# Only run compinit once a day to keep startup fast; otherwise use the cache
if [[ -n ~/.zcompdump(#qN.m-1) ]]; then
    compinit
else
    compinit -C
fi

# --- Key bindings ---
bindkey -M viins ',,' vi-cmd-mode   # ,, to switch from insert to normal mode
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line   # open current command line in $EDITOR

# --- Functions ---
# Rename the current tmux window; useful to label long-running tasks
function tmux_win_name () {
    if [ "$TMUX" ]; then
        tmux rename-window $1
    fi
}

# --- Sources ---
source ~/.zsh/alias.zsh
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# --- PATH ---
export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# Disable Ctrl+S flow control (which would otherwise freeze the terminal)
stty stop undef
