# vim: ft=zsh

# --- Environment ---
# XDG_CONFIG_HOME: Linux standard also respected by Neovim and some cross-platform
# tools on macOS (e.g. nvim config lives at $XDG_CONFIG_HOME/nvim/)
export XDG_CONFIG_HOME=$HOME/.config/

export VISUAL=nvim
export EDITOR=nvim
# -R: preserve color escape sequences
# -X: don't use alternate screen, so output stays in scrollback history after exit
export LESS="-R -X"

# --- PATH ---
# Initialize Homebrew (sets PATH, MANPATH, HOMEBREW_PREFIX, HOMEBREW_CELLAR, etc.)
eval "$(/opt/homebrew/bin/brew shellenv)"

# --- Linux only ---
# The following have no effect on macOS; kept here for portability

# Fixes Java AWT GUIs under non-reparenting window managers (e.g. xmonad, i3)
export _JAVA_AWT_WM_NONREPARENTING

# Start D-Bus session if available (Linux desktop session bus)
if type dbus-launch > /dev/null 2>&1; then
    export $(dbus-launch)
fi
